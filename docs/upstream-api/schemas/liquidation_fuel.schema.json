{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mm.local/schemas/liquidation_fuel.schema.json",
  "title": "HFD pro_data response: liquidation_fuel",
  "type": "object",
  "properties": {
    "klines": {
      "type": "array",
      "description": "Array of 4923 items in sample",
      "items": {
        "type": "array",
        "description": "HFD kline tuple (NON-STANDARD ORDER): [ts, open, close, low, high, volume]",
        "minItems": 6,
        "maxItems": 6,
        "items": [
          {
            "type": "integer",
            "description": "ts (ms epoch, kline open time)"
          },
          {
            "type": "number",
            "description": "open"
          },
          {
            "type": "number",
            "description": "close (★ comes before high, unlike Binance/OKX)"
          },
          {
            "type": "number",
            "description": "low"
          },
          {
            "type": "number",
            "description": "high"
          },
          {
            "type": "number",
            "description": "volume"
          }
        ]
      }
    },
    "liquidation_fuel": {
      "type": "array",
      "description": "Array of 29 items in sample",
      "items": {
        "type": "object",
        "properties": {
          "bottom": {
            "type": "number"
          },
          "fuel": {
            "type": "number"
          },
          "top": {
            "type": "number"
          }
        },
        "required": [
          "bottom",
          "fuel",
          "top"
        ]
      }
    }
  },
  "required": [
    "klines",
    "liquidation_fuel"
  ]
}