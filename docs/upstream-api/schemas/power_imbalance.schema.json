{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mm.local/schemas/power_imbalance.schema.json",
  "title": "HFD pro_data response: power_imbalance",
  "type": "object",
  "properties": {
    "klines": {
      "type": "array",
      "description": "Array of 4923 items in sample",
      "items": {
        "type": "array",
        "description": "HFD kline tuple (NON-STANDARD ORDER): [ts, open, close, low, high, volume]",
        "minItems": 6,
        "maxItems": 6,
        "items": [
          {
            "type": "integer",
            "description": "ts (ms epoch, kline open time)"
          },
          {
            "type": "number",
            "description": "open"
          },
          {
            "type": "number",
            "description": "close (★ comes before high, unlike Binance/OKX)"
          },
          {
            "type": "number",
            "description": "low"
          },
          {
            "type": "number",
            "description": "high"
          },
          {
            "type": "number",
            "description": "volume"
          }
        ]
      }
    },
    "power_imbalance": {
      "type": "array",
      "description": "Array of 4923 items in sample",
      "items": {
        "type": "object",
        "properties": {
          "buy_vol": {
            "type": "integer"
          },
          "ratio": {
            "type": "integer"
          },
          "sell_vol": {
            "type": "integer"
          },
          "timestamp": {
            "type": "integer"
          }
        },
        "required": [
          "buy_vol",
          "ratio",
          "sell_vol",
          "timestamp"
        ]
      }
    }
  },
  "required": [
    "klines",
    "power_imbalance"
  ]
}