{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mm.local/schemas/hvn_nodes.schema.json",
  "title": "HFD pro_data response: hvn_nodes",
  "type": "object",
  "properties": {
    "hvn_nodes": {
      "type": "array",
      "description": "Array of 10 items in sample",
      "items": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number"
          },
          "volume": {
            "type": "number"
          }
        },
        "required": [
          "price",
          "volume"
        ]
      }
    },
    "klines": {
      "type": "array",
      "description": "Array of 4923 items in sample",
      "items": {
        "type": "array",
        "description": "HFD kline tuple (NON-STANDARD ORDER): [ts, open, close, low, high, volume]",
        "minItems": 6,
        "maxItems": 6,
        "items": [
          {
            "type": "integer",
            "description": "ts (ms epoch, kline open time)"
          },
          {
            "type": "number",
            "description": "open"
          },
          {
            "type": "number",
            "description": "close (★ comes before high, unlike Binance/OKX)"
          },
          {
            "type": "number",
            "description": "low"
          },
          {
            "type": "number",
            "description": "high"
          },
          {
            "type": "number",
            "description": "volume"
          }
        ]
      }
    }
  },
  "required": [
    "hvn_nodes",
    "klines"
  ]
}