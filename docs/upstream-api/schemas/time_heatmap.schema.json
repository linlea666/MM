{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mm.local/schemas/time_heatmap.schema.json",
  "title": "HFD pro_data response: time_heatmap",
  "type": "object",
  "properties": {
    "klines": {
      "type": "array",
      "description": "Array of 4923 items in sample",
      "items": {
        "type": "array",
        "description": "HFD kline tuple (NON-STANDARD ORDER): [ts, open, close, low, high, volume]",
        "minItems": 6,
        "maxItems": 6,
        "items": [
          {
            "type": "integer",
            "description": "ts (ms epoch, kline open time)"
          },
          {
            "type": "number",
            "description": "open"
          },
          {
            "type": "number",
            "description": "close (★ comes before high, unlike Binance/OKX)"
          },
          {
            "type": "number",
            "description": "low"
          },
          {
            "type": "number",
            "description": "high"
          },
          {
            "type": "number",
            "description": "volume"
          }
        ]
      }
    },
    "time_heatmap": {
      "type": "array",
      "description": "Array of 24 items in sample",
      "items": {
        "type": "object",
        "properties": {
          "accum": {
            "type": "number"
          },
          "dist": {
            "type": "number"
          },
          "hour": {
            "type": "integer"
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "accum",
          "dist",
          "hour",
          "total"
        ]
      }
    }
  },
  "required": [
    "klines",
    "time_heatmap"
  ]
}