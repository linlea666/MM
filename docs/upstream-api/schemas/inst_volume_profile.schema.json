{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mm.local/schemas/inst_volume_profile.schema.json",
  "title": "HFD pro_data response: inst_volume_profile",
  "type": "object",
  "properties": {
    "klines": {
      "type": "array",
      "description": "Array of 4923 items in sample",
      "items": {
        "type": "array",
        "description": "HFD kline tuple (NON-STANDARD ORDER): [ts, open, close, low, high, volume]",
        "minItems": 6,
        "maxItems": 6,
        "items": [
          {
            "type": "integer",
            "description": "ts (ms epoch, kline open time)"
          },
          {
            "type": "number",
            "description": "open"
          },
          {
            "type": "number",
            "description": "close (★ comes before high, unlike Binance/OKX)"
          },
          {
            "type": "number",
            "description": "low"
          },
          {
            "type": "number",
            "description": "high"
          },
          {
            "type": "number",
            "description": "volume"
          }
        ]
      }
    },
    "order_blocks": {
      "type": "array",
      "description": "Array of 0 items in sample",
      "items": {}
    },
    "volume_profile": {
      "type": "array",
      "description": "Array of 48 items in sample",
      "items": {
        "type": "object",
        "properties": {
          "accum": {
            "type": "number"
          },
          "dist": {
            "type": "number"
          },
          "price": {
            "type": "number"
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "accum",
          "dist",
          "price",
          "total"
        ]
      }
    }
  },
  "required": [
    "klines",
    "order_blocks",
    "volume_profile"
  ]
}